detect
event: json
op: and
rules:
  - op: is
    path: event/ext_name
    value: ext-yara
  - op: matches
    path: event/data/rule_name
    re: ^my-rule
target: deployment

response 
- action: task
  command: history_isolate
  suppression:
    is_global: false
    keys:
      - '{{ .routing.sid }}'
      - yara-isolation-suppression
    max_count: 1
    period: 1h
