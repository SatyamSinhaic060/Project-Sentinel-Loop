detect
events:
  - NEW_PROCESS
  - EXISTING_PROCESS
op: and
rules:
  - op: is windows
  - case sensitive: false
    op: contains
    path: event/COMMAND_LINE
    value: \SOFTWARE\Policies\Microsoft\FVE
  - case sensitive: false
    op: contains
    path: event/COMMAND_LINE
    value: ADD
  - case sensitive: false
    op: contains
    path: event/COMMAND_LINE
    value: /v
  - case sensitive: false
    op: contains
    path: event/COMMAND_LINE
    value: /f
  - op: or
    rules:
      - case sensitive: false
        op: contains
        path: event/COMMAND_LINE
        value: EnableBDEWithNoTPM
      - case sensitive: false
        op: contains
        path: event/COMMAND_LINE
        value: UseAdvancedStartup
      - case sensitive: false
        op: contains
        path: event/COMMAND_LINE
        value: UseTPMPIN
      - case sensitive: false
        op: contains
        path: event/COMMAND_LINE
        value: UseTPMKey
      - case sensitive: false
        op: contains
        path: event/COMMAND_LINE
        value: UseTPMKeyPIN
      - case sensitive: false
        op: contains
        path: event/COMMAND_LINE
        value: UseTPM
      - case sensitive: false
        op: contains
        path: event/COMMAND_LINE
        value: RecoveryKeyMessageSource
      - case sensitive: false
        op: contains
        path: event/COMMAND_LINE
        value: RecoveryKeyMessage

response
- action: report
  metadata:
    author: frack113
    description: >-
      Detects malicious modifications to BitLocker Group Policy overrides via
      reg.exe.
    level: high
    mitre_attack:
      - T1486
    tags:
      - attack.impact
      - attack.t1486
  name: Suspicious Reg Add BitLocker Modification on {{ .routing.hostname }}
- action: task
  command: history_dump
  investigation: bitlocker-tampering-forensics
  suppression:
    is_global: false
    keys:
      - '{{ .routing.sid }}'
      - bitlocker-history-dump
    max_count: 1
    period: 15m
- action: task
  command: artifact_get --file "{{ .event.PARENT.FILE_PATH }}" --days-retention 30
  investigation: bitlocker-tampering-forensics
  suppression:
    is_global: false
    keys:
      - '{{ .routing.sid }}'
      - '{{ .event.PARENT.FILE_PATH }}'
      - bitlocker-parent-grab
    max_count: 1
    period: 15m
- action: extension request
  extension action: '{{ "collect" }}'
  extension name: ext-velociraptor
  extension request:
    args: ProcessRegex="(?i)powershell|cmd|ProjectCerberus"
    artifact_list:
      - '{{ "Windows.Memory.PEDump" }}'
    sid: '{{ .routing.sid }}'
  suppression:
    is_global: false
    keys:
      - '{{ .routing.sid }}'
      - velociraptor-bitlocker-pedump
    max_count: 1
    period: 15m
- action: extension request
  extension action: request
  extension name: ext-webhook
  extension request:
    body:
      event: '{{ .event }}'
      hostname: '{{ .routing.hostname }}'
      sid: '{{ .routing.sid }}'
    method: POST
    url: >-
      https://n8n-webhook-url
  suppression:
    is_global: false
    keys:
      - '{{ .routing.sid }}'
      - n8n-webhook-trigger
    max_count: 1
    period: 10m
- action: task
  command: deny_tree {{ .routing.this }}
  investigation: bitlocker-tampering-remediation
